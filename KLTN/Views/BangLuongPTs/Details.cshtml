@model KLTN.Models.Database.BangLuongPT

@{
    ViewData["Title"] = "Chi tiết bảng lương";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Chi tiết bảng lương huấn luyện viên</h1>
        <div class="flex items-center mt-2">
            <span class="text-gray-600">
                Huấn luyện viên: <span class="font-semibold">@Model.HuanLuyenVien?.HoTen</span> | 
                Tháng: <span class="font-semibold">@Model.ThangNam.ToString("MM/yyyy")</span>
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white shadow-md rounded-lg p-6">
            <h2 class="text-xl font-bold text-gray-800 mb-4">Thông tin tổng quan</h2>
            
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <p class="text-sm text-gray-500">Lương cơ bản</p>
                    <p class="text-lg font-semibold text-gray-800">@Model.LuongCoBan.ToString("#,##0") VNĐ</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Tổng doanh thu</p>
                    <p class="text-lg font-semibold text-blue-600">@Model.TongDoanhThu.ToString("#,##0") VNĐ</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Tổng hoa hồng</p>
                    <p class="text-lg font-semibold text-green-600">@Model.TongHoaHong.ToString("#,##0") VNĐ</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Tổng thanh toán</p>
                    <p class="text-lg font-semibold text-blue-600">@Model.TongThanhToan.ToString("#,##0") VNĐ</p>
                </div>

<div>
                    <p class="text-sm text-gray-500">Trạng thái</p>
                    <p>
                        @if (Model.TrangThai == "DaThanhToan")
                        {
                            <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                Đã thanh toán
                            </span>
                        }
                        else
                        {
                            <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                                Chưa thanh toán
                            </span>
                        }
                    </p>
</div>
                
<div>
                    <p class="text-sm text-gray-500">Ngày thanh toán</p>
                    <p class="text-base text-gray-800">
                        @(Model.NgayThanhToan.HasValue ? Model.NgayThanhToan.Value.ToString("dd/MM/yyyy") : "Chưa thanh toán")
                    </p>
                </div>
            </div>
            
            @if (!string.IsNullOrEmpty(Model.GhiChu))
            {
                <div class="mt-4">
                    <p class="text-sm text-gray-500">Ghi chú</p>
                    <p class="text-base text-gray-800 mt-1">@Model.GhiChu</p>
                </div>
            }
        </div>
        
        <div class="bg-white shadow-md rounded-lg p-6">
            <h2 class="text-xl font-bold text-gray-800 mb-4">Thao tác</h2>
            
            <div class="grid grid-cols-2 gap-3 mb-6">
                <div class="p-4 border border-blue-200 rounded-md bg-blue-50">
                    <p class="font-medium text-blue-800">Tổng số buổi dạy</p>
                    <p class="text-2xl font-bold text-blue-600">
                        @(Model.PhienDaysTrongKyLuong?.Count ?? 0)
                    </p>
                </div>
                <div class="p-4 border border-green-200 rounded-md bg-green-50">
                    <p class="font-medium text-green-800">Tổng thu nhập</p>
                    <p class="text-2xl font-bold text-green-600">
                        @Model.TongThanhToan.ToString("#,##0") VNĐ
                    </p>
                </div>
            </div>
            
            <div class="flex flex-wrap gap-2">
                @if (Model.TrangThai != "DaThanhToan")
                {
                    <a asp-action="TinhLuong" asp-route-id="@Model.MaLuong" 
                       class="px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700 transition">
                        <i class="bi bi-calculator me-1"></i> Tính lương lại
                    </a>
                    <a asp-action="ThanhToanLuong" asp-route-id="@Model.MaLuong" 
                       class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition">
                        <i class="bi bi-cash-coin me-1"></i> Thanh toán
                    </a>
                }
                
                <a asp-action="Edit" asp-route-id="@Model.MaLuong" 
                   class="px-4 py-2 bg-yellow-600 text-white rounded hover:bg-yellow-700 transition">
                    <i class="bi bi-pencil me-1"></i> Sửa
                </a>
                <a asp-action="Index" 
                   class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700 transition">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
    
    <div class="bg-white shadow-md rounded-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Danh sách phiên dạy</h2>
        
        @if (Model.PhienDaysTrongKyLuong?.Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ngày dạy</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Loại dịch vụ</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tên dịch vụ</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Giá trị buổi dạy</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phần trăm hoa hồng</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tiền hoa hồng</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var phien in Model.PhienDaysTrongKyLuong)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-900">@phien.NgayDay.ToString("dd/MM/yyyy HH:mm")</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-900">
                                        @if (phien.LoaiDichVu == "LopHoc")
                                        {
                                            <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">Lớp học</span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-1 text-xs rounded-full bg-purple-100 text-purple-800">Gói tập</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900">
                                        @if (phien.LoaiDichVu == "LopHoc" && phien.LopHoc != null)
                                        {
                                            @phien.LopHoc.TenLop
                                        }
                                        else if (phien.GoiTap != null)
                                        {
                                            @phien.GoiTap.TenGoi
                                        }
                                        else
                                        {
                                            <span>Không xác định</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-900">@phien.GiaTriBuoiDay.ToString("#,##0") VNĐ</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @{
                                        decimal phanTramHoaHong = 0;
                                        
                                        if (phien.LoaiDichVu == "LopHoc" && phien.MaLopHoc.HasValue)
                                        {
                                            var hoaHongLopHoc = ViewBag.PhanCongHoaHongs?.FirstOrDefault(
                                                (Func<dynamic, bool>)(pt => pt.MaPT == Model.MaPT && pt.MaLopHoc == phien.MaLopHoc.Value));
                                            
                                            if (hoaHongLopHoc != null)
                                            {
                                                phanTramHoaHong = hoaHongLopHoc.PhanTramHoaHong;
                                            }
                                        }
                                        else if (phien.LoaiDichVu == "GoiTap" && phien.MaGoiTap.HasValue)
                                        {
                                            var hoaHongGoiTap = ViewBag.PhanCongHoaHongs?.FirstOrDefault(
                                                (Func<dynamic, bool>)(pt => pt.MaPT == Model.MaPT && pt.MaGoiTap == phien.MaGoiTap.Value));
                                            
                                            if (hoaHongGoiTap != null)
                                            {
                                                phanTramHoaHong = hoaHongGoiTap.PhanTramHoaHong;
                                            }
                                        }
                                    }
                                    <div class="text-sm text-gray-900">@phanTramHoaHong.ToString("0.##")%</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900">
                                        @{
                                            decimal hoaHongPhien = phien.GiaTriBuoiDay * (phanTramHoaHong / 100);
                                        }
                                        @hoaHongPhien.ToString("#,##0") VNĐ
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-8 bg-gray-50 rounded-md">
                <p class="text-gray-500">Chưa có phiên dạy nào được tính vào bảng lương này</p>
                <a asp-action="TinhLuong" asp-route-id="@Model.MaLuong" 
                   class="inline-block mt-3 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
                    <i class="bi bi-calculator me-1"></i> Tính lương ngay
                </a>
            </div>
        }
    </div>
</div>
