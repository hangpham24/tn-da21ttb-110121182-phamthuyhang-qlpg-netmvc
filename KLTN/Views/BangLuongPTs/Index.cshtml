@model IEnumerable<KLTN.Models.Database.BangLuongPT>

@{
    ViewData["Title"] = "Quản lý lương huấn luyện viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Quản lý lương huấn luyện viên</h1>
        <a asp-action="Create" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
            <i class="bi bi-plus-circle me-1"></i> Tạo bảng lương mới
        </a>
    </div>

    <div class="overflow-x-auto bg-white shadow-md rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.HuanLuyenVien)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.ThangNam)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.LuongCoBan)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.TongHoaHong)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.TongThanhToan)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.TrangThai)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Thao tác
                    </th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
            @foreach (var item in Model) {
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-medium text-gray-900">
                            @(item.HuanLuyenVien != null ? item.HuanLuyenVien.HoTen : "Không xác định")
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-gray-900">@item.ThangNam.ToString("MM/yyyy")</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-gray-900">@item.LuongCoBan.ToString("#,##0") VNĐ</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-gray-900">@item.TongHoaHong.ToString("#,##0") VNĐ</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-medium text-gray-900">@item.TongThanhToan.ToString("#,##0") VNĐ</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        @if (item.TrangThai == "DaThanhToan")
                        {
                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                Đã thanh toán
                            </span>
                        }
                        else
                        {
                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                                Chưa thanh toán
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                        <div class="flex space-x-2">
                            <a asp-action="Details" asp-route-id="@item.MaLuong" class="text-blue-600 hover:text-blue-900">
                                <i class="bi bi-eye"></i> Chi tiết
                            </a>
                            
                            @if (item.TrangThai != "DaThanhToan")
                            {
                                <a asp-action="TinhLuong" asp-route-id="@item.MaLuong" class="text-indigo-600 hover:text-indigo-900">
                                    <i class="bi bi-calculator"></i> Tính lương
                                </a>
                                <a asp-action="ThanhToanLuong" asp-route-id="@item.MaLuong" class="text-green-600 hover:text-green-900">
                                    <i class="bi bi-cash-coin"></i> Thanh toán
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.MaLuong" class="text-yellow-600 hover:text-yellow-900">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                            }
                            
                            <a asp-action="Delete" asp-route-id="@item.MaLuong" class="text-red-600 hover:text-red-900">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
