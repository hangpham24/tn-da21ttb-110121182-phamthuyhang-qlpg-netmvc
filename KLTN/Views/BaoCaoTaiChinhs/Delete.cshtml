@model KLTN.Models.Database.BaoCaoTaiChinh

@{
    ViewData["Title"] = "Xóa báo cáo tài chính";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 mb-6">
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Xóa báo cáo tài chính</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Bạn có chắc chắn muốn xóa báo cáo tài chính này?</p>
    </div>

    <div class="max-w-3xl">
        <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.Thang)
                    </h3>
                    <p class="mt-1 text-base font-semibold text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.Thang)
                    </p>
                </div>
                
                <div>
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.Nam)
                    </h3>
                    <p class="mt-1 text-base font-semibold text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.Nam)
                    </p>
                </div>
                
                <div>
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.TongDoanhThu)
                    </h3>
                    <p class="mt-1 text-base font-semibold text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.TongDoanhThu) VNĐ
                    </p>
                </div>
                
                <div>
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.NgayLapBaoCao)
                    </h3>
                    <p class="mt-1 text-base font-semibold text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.NgayLapBaoCao)
                    </p>
                </div>
                
                <div>
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.TrangThai)
                    </h3>
                    @{
                        string badgeClass = "bg-blue-100 text-blue-800";
                        if (Model.TrangThai == "Đã duyệt")
                        {
                            badgeClass = "bg-green-100 text-green-800";
                        }
                        else if (Model.TrangThai == "Chờ duyệt")
                        {
                            badgeClass = "bg-yellow-100 text-yellow-800";
                        }
                        else if (Model.TrangThai == "Từ chối")
                        {
                            badgeClass = "bg-red-100 text-red-800";
                        }
                    }
                    <p class="mt-1">
                        <span class="@badgeClass text-xs font-medium mr-2 px-2.5 py-0.5 rounded">
                            @Html.DisplayFor(model => model.TrangThai)
                        </span>
                    </p>
                </div>
                
                <div>
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.TaiKhoan)
                    </h3>
                    <p class="mt-1 text-base font-semibold text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.TaiKhoan.TenDangNhap)
                    </p>
                </div>
                
                <div class="md:col-span-2">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.GhiChu)
                    </h3>
                    <p class="mt-1 text-base text-gray-900 dark:text-white">
                        @if(string.IsNullOrEmpty(Model.GhiChu))
                        {
                            <span class="text-gray-400 dark:text-gray-500">Không có ghi chú</span>
                        }
                        else
                        {
                            @Html.DisplayFor(model => model.GhiChu)
                        }
                    </p>
                </div>
            </div>
        </div>
        
        <div class="flex items-center space-x-4">
            <form asp-action="Delete">
                <input type="hidden" asp-for="MaBaoCao" />
                <button type="submit" class="text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-800">
                    <i class="bi bi-trash mr-2"></i>Xác nhận xóa
                </button>
                <a asp-action="Index" class="ml-4 text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-200 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700">
                    <i class="bi bi-arrow-left mr-2"></i>Quay lại
                </a>
            </form>
        </div>
    </div>
</div>
