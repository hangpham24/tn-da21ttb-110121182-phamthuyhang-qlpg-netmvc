@model KLTN.Models.ViewModels.DangKyOnlineViewModel

@{
    ViewData["Title"] = "Xác nhận đăng ký dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-3xl mx-auto">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
            <a asp-action="Index" asp-controller="DichVus" class="text-blue-600 hover:text-blue-700">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="bg-white shadow-lg rounded-lg overflow-hidden">
            <div class="p-6">
                <div class="mb-8">
                    <h2 class="text-xl font-semibold text-gray-800 mb-4">Thông tin dịch vụ</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-600">Tên dịch vụ</label>
                            <p class="mt-1 text-gray-900">@Model.TenDichVu</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-600">Loại dịch vụ</label>
                            <p class="mt-1 text-gray-900">@(Model.LoaiDichVu == "LopHoc" ? "Lớp học" : "Gói tập")</p>
                        </div>
                        @if (Model.LoaiDichVu == "LopHoc")
                        {
                            <div>
                                <label class="block text-sm font-medium text-gray-600">Tên lớp</label>
                                <p class="mt-1 text-gray-900">@Model.TenLopHoc</p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-600">Lịch học</label>
                                <p class="mt-1 text-gray-900">@Model.LichHoc</p>
                            </div>
                        }
                        <div>
                            <label class="block text-sm font-medium text-gray-600">Giá dịch vụ</label>
                            <p class="mt-1 text-gray-900">@Model.GiaDichVu.ToString("N0") VNĐ</p>
                        </div>
                    </div>
                </div>

                <div class="mb-8">
                    <h2 class="text-xl font-semibold text-gray-800 mb-4">Thông tin thành viên</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-600">Họ tên</label>
                            <p class="mt-1 text-gray-900">@Model.TenThanhVien</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-600">Email</label>
                            <p class="mt-1 text-gray-900">@Model.Email</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-600">Số điện thoại</label>
                            <p class="mt-1 text-gray-900">@Model.SoDienThoai</p>
                        </div>
                    </div>
                </div>

                <form asp-action="DangKyOnline" method="post" class="space-y-6">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
                    
                    <input type="hidden" asp-for="DichVuId" />
                    <input type="hidden" asp-for="TenDichVu" />
                    <input type="hidden" asp-for="LoaiDichVu" />
                    <input type="hidden" asp-for="GiaDichVu" />
                    <input type="hidden" asp-for="TenThanhVien" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="SoDienThoai" />
                    
                    <div>
                        <label asp-for="NgayBatDau" class="block text-sm font-medium text-gray-700">Ngày bắt đầu</label>
                        <input asp-for="NgayBatDau" type="date" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" />
                        <span asp-validation-for="NgayBatDau" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="GhiChu" class="block text-sm font-medium text-gray-700">Ghi chú</label>
                        <textarea asp-for="GhiChu" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Nhập ghi chú nếu có"></textarea>
                        <span asp-validation-for="GhiChu" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="flex justify-end space-x-3">
                        <a asp-controller="DichVus" asp-action="PublicDetails" asp-route-id="@Model.DichVuId" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-gray-700 bg-gray-200 hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                            Hủy
                        </a>
                        <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                            Xác nhận đăng ký
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
} 