@model KLTN.Models.Database.DichVu

@{
    ViewData["Title"] = "Xóa dịch vụ";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 mb-6">
    <div class="mb-6">
        <div class="flex justify-between items-center mb-4">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Xóa dịch vụ</h1>
            <a asp-action="Index" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 focus:ring-4 focus:ring-gray-300 font-medium text-sm">
                <i class="bi bi-arrow-left mr-1"></i> Quay lại
            </a>
        </div>
        <hr class="h-px my-4 bg-gray-200 border-0 dark:bg-gray-700">
        
        <div class="p-4 mb-4 text-yellow-800 border border-yellow-300 rounded-lg bg-yellow-50 dark:bg-gray-800 dark:text-yellow-300 dark:border-yellow-800" role="alert">
            <div class="flex items-center">
                <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mr-2"></i>
                <span class="font-medium">Cảnh báo!</span>
            </div>
            <div class="mt-2">Bạn có chắc chắn muốn xóa dịch vụ này? Hành động này không thể hoàn tác.</div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg shadow mb-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Thông tin dịch vụ</h3>
                <dl class="grid grid-cols-1 gap-4">
                    <div class="grid grid-cols-3">
                        <dt class="col-span-1 font-medium text-gray-700 dark:text-gray-300">@Html.DisplayNameFor(model => model.TenDichVu)</dt>
                        <dd class="col-span-2 text-gray-900 dark:text-white">@Html.DisplayFor(model => model.TenDichVu)</dd>
                    </div>
                    <div class="grid grid-cols-3">
                        <dt class="col-span-1 font-medium text-gray-700 dark:text-gray-300">@Html.DisplayNameFor(model => model.LoaiDichVu)</dt>
                        <dd class="col-span-2 text-gray-900 dark:text-white">@Html.DisplayFor(model => model.LoaiDichVu)</dd>
                    </div>
                    <div class="grid grid-cols-3">
                        <dt class="col-span-1 font-medium text-gray-700 dark:text-gray-300">@Html.DisplayNameFor(model => model.GiaBatDau)</dt>
                        <dd class="col-span-2 text-gray-900 dark:text-white">@Html.DisplayFor(model => model.GiaBatDau) VNĐ</dd>
                    </div>
                    <div class="grid grid-cols-3">
                        <dt class="col-span-1 font-medium text-gray-700 dark:text-gray-300">@Html.DisplayNameFor(model => model.MoTa)</dt>
                        <dd class="col-span-2 text-gray-900 dark:text-white">@Html.DisplayFor(model => model.MoTa)</dd>
                    </div>
                </dl>
            </div>
            
            @if (Model.LoaiDichVu == "GoiTap" && Model.GoiTap != null)
            {
                <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg shadow">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Thông tin gói tập</h3>
                    <dl class="grid grid-cols-1 gap-4">
                        <div class="grid grid-cols-3">
                            <dt class="col-span-1 font-medium text-gray-700 dark:text-gray-300">Tên gói</dt>
                            <dd class="col-span-2 text-gray-900 dark:text-white">@Html.DisplayFor(model => model.GoiTap.TenGoi)</dd>
                        </div>
                    </dl>
                </div>
            }
            
            @if (Model.LoaiDichVu == "LopHoc" && Model.LopHoc != null)
            {
                <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg shadow">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Thông tin lớp học</h3>
                    <dl class="grid grid-cols-1 gap-4">
                        <div class="grid grid-cols-3">
                            <dt class="col-span-1 font-medium text-gray-700 dark:text-gray-300">Ngày trong tuần</dt>
                            <dd class="col-span-2 text-gray-900 dark:text-white">@Html.DisplayFor(model => model.LopHoc.NgayTrongTuan)</dd>
                        </div>
                    </dl>
                </div>
            }
        </div>
        
        <div>
            @if (!string.IsNullOrEmpty(Model.HinhAnhURL))
            {
                <div class="mb-6">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Hình ảnh</h3>
                    <img src="@Model.HinhAnhURL" alt="@Model.TenDichVu" class="w-full h-64 object-cover rounded-lg shadow-md" 
                         onerror="this.onerror=null; this.src='/img/placeholder.jpg'; this.alt='Hình ảnh không khả dụng';" />
                </div>
            }
        </div>
    </div>
    
    <form asp-action="Delete" class="mt-6">
        <input type="hidden" asp-for="MaDichVu" />
        <div class="flex items-center justify-center space-x-4">
            <button type="submit" class="text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-800">
                <i class="bi bi-trash mr-1"></i> Xác nhận xóa
            </button>
            <a asp-action="Index" class="py-2.5 px-5 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700">
                Hủy
            </a>
        </div>
    </form>
</div>
