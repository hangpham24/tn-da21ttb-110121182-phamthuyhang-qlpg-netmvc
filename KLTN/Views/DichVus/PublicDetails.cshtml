@model KLTN.Models.Database.DichVu
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject KLTN.Data.ApplicationDbContext _context

@{
    ViewData["Title"] = "Chi tiết dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool IsThanhVien()
    {
        if (!User.Identity.IsAuthenticated) return false;

        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrEmpty(userId)) return false;

        var taiKhoan = _context.TaiKhoans
            .Include(t => t.Quyen)
            .FirstOrDefault(t => t.MaTK.ToString() == userId);

        return taiKhoan?.Quyen?.TenQuyen == "Thành viên";
    }
}

<!-- Banner chi tiết dịch vụ -->
<div class="relative bg-gradient-to-r from-blue-600 to-indigo-700 py-12 mb-8 rounded-xl overflow-hidden">
    <div class="absolute inset-0 opacity-20 bg-pattern"></div>
    <div class="container mx-auto px-4 relative z-10">
        <div class="text-center">
            <h1 class="text-3xl font-bold text-white mb-2">@Model.TenDichVu</h1>
            <p class="text-lg text-white/80 max-w-3xl mx-auto">
                @{
                    var serviceTypeText = Model.LoaiDichVu switch {
                        "GoiTap" => "Gói tập",
                        "LopHoc" => "Lớp học",
                        _ => Model.LoaiDichVu
                    };
                }
                @serviceTypeText - @string.Format("{0:N0} VNĐ", Model.GiaBatDau)
            </p>
        </div>
    </div>
</div>

<div class="container mx-auto px-4 py-8">
    <div class="bg-white dark:bg-gray-800 shadow-lg rounded-lg overflow-hidden">
        <div class="p-6">
            <h2 class="text-2xl font-bold mb-4 text-gray-800 dark:text-white">@Model.TenDichVu</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <h3 class="text-xl font-semibold mb-3 text-gray-700 dark:text-gray-300">Thông tin chung</h3>
                    <div class="space-y-2">
                        <p class="text-gray-600 dark:text-gray-400">
                            <span class="font-medium">Giá:</span> @Model.GiaBatDau.ToString("N0") VNĐ
                        </p>
                        <p class="text-gray-600 dark:text-gray-400">
                            <span class="font-medium">Loại dịch vụ:</span> @Model.LoaiDichVu
                        </p>
                        @if (Model.LoaiDichVu == "LopHoc")
                        {
                            <p class="text-gray-600 dark:text-gray-400">
                                <span class="font-medium">Lịch học:</span> @Model.LopHoc?.NgayTrongTuan
                            </p>
                            <p class="text-gray-600 dark:text-gray-400">
                                <span class="font-medium">Số lượng tối đa:</span> @Model.LopHoc?.SoLuongToiDa người
                            </p>
                        }
                    </div>
                </div>
                
                <div>
                    <h3 class="text-xl font-semibold mb-3 text-gray-700 dark:text-gray-300">Mô tả</h3>
                    <p class="text-gray-600 dark:text-gray-400">@Model.MoTa</p>
                </div>
            </div>

            <div class="flex justify-center pt-4">
                @if (IsThanhVien())
                {
                    <a href="@Url.Action("DangKyOnline", "DangKies", new { dichVuId = Model.MaDichVu, loaiDichVu = Model.LoaiDichVu })" class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition duration-300 transform hover:-translate-y-1">
                        <i class="bi bi-pencil-square mr-2"></i>
                        Đăng ký ngay
                    </a>
                }
                else
                {
                    <div class="text-center">
                        <p class="text-gray-600 dark:text-gray-400 mb-2">Bạn cần đăng nhập với tài khoản thành viên để đăng ký dịch vụ</p>
                        <a href="/Account/Login" class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition duration-300">
                            <i class="bi bi-box-arrow-in-right mr-2"></i>
                            Đăng nhập
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Các dịch vụ liên quan -->
<div class="container mx-auto px-4 mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Có thể bạn quan tâm</h2>
    
    <div id="relatedServices" class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gray-100 animate-pulse rounded-xl overflow-hidden h-80"></div>
        <div class="bg-gray-100 animate-pulse rounded-xl overflow-hidden h-80 hidden md:block"></div>
        <div class="bg-gray-100 animate-pulse rounded-xl overflow-hidden h-80 hidden md:block"></div>
    </div>
</div>

@section Scripts {
    <script>
        // Tải dịch vụ liên quan
        document.addEventListener('DOMContentLoaded', function() {
            fetch('/DichVus/GetRelatedServices?id=@Model.MaDichVu&loaiDichVu=@Model.LoaiDichVu')
                .then(response => response.text())
                .then(html => {
                    document.getElementById('relatedServices').innerHTML = html;
                })
                .catch(error => {
                    console.error('Không thể tải dịch vụ liên quan:', error);
                });
        });
    </script>
} 