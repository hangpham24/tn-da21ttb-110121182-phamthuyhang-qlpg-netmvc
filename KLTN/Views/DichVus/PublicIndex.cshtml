@model IEnumerable<KLTN.Models.Database.DichVu>

@{
    ViewData["Title"] = "Dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Banner -->
<div class="relative bg-gradient-to-r from-blue-600 to-indigo-700 py-12 mb-8 rounded-xl overflow-hidden">
    <div class="absolute inset-0 opacity-20 bg-pattern"></div>
    <div class="container mx-auto px-4 relative z-10">
        <div class="text-center">
            <h1 class="text-4xl font-bold text-white mb-4">Dịch vụ</h1>
            <p class="text-lg text-white/80 max-w-2xl mx-auto">Khám phá các dịch vụ đa dạng và các gói tập chất lượng cao tại phòng gym của chúng tôi</p>
        </div>
    </div>
</div>

<!-- Tìm kiếm và lọc -->
<div class="container mx-auto px-4 mb-8">
    <div class="bg-white rounded-xl shadow-md p-6">
        <form method="get" class="flex flex-col sm:flex-row gap-4">
            <div class="flex-1">
                <label for="search" class="block text-sm font-medium text-gray-700 mb-1">Tìm kiếm dịch vụ</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="bi bi-search text-gray-400"></i>
                    </div>
                    <input type="text" name="search" id="search" value="@Context.Request.Query["search"]" placeholder="Tìm kiếm theo tên, mô tả..." 
                           class="pl-10 w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500">
                </div>
            </div>
            <div class="sm:w-48">
                <label for="loaiDichVu" class="block text-sm font-medium text-gray-700 mb-1">Loại dịch vụ</label>
                <select name="loaiDichVu" id="loaiDichVu" 
                        class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500">
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.LoaiDichVu)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>
            <div class="flex items-end gap-2">
                <button type="submit" class="inline-flex items-center justify-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300">
                    <i class="bi bi-search mr-2"></i> Tìm kiếm
                </button>
                <a href="@Url.Action("PublicIndex")" class="inline-flex items-center justify-center px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 focus:ring-4 focus:ring-gray-200">
                    <i class="bi bi-x-circle mr-2"></i> Xóa bộ lọc
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Danh sách dịch vụ -->
<div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition duration-300 transform hover:-translate-y-1 group">
                <div class="relative h-64 overflow-hidden">
                    @if (item.LoaiDichVu == "GoiTap")
                    {
                        <img src="/img/gym01.jpg" alt="@item.TenDichVu" class="w-full h-full object-cover group-hover:scale-105 transition duration-300" />
                    }
                    else if (!string.IsNullOrEmpty(item.HinhAnhURL))
                    {
                        <img src="@item.HinhAnhURL" alt="@item.TenDichVu" class="w-full h-full object-cover group-hover:scale-105 transition duration-300" 
                             onerror="this.onerror=null; this.src='/img/placeholder.jpg'; this.alt='Hình ảnh không khả dụng';" />
                    }
                    else
                    {
                        <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                            <span class="text-gray-400"><i class="bi bi-image text-4xl"></i></span>
                        </div>
                    }
                </div>
                <div class="p-6">
                    @{
                        var serviceTypeClass = item.LoaiDichVu switch {
                            "GoiTap" => "bg-blue-100 text-blue-800",
                            "LopHoc" => "bg-green-100 text-green-800",
                            _ => "bg-gray-100 text-gray-800"
                        };
                        var serviceTypeText = item.LoaiDichVu switch {
                            "GoiTap" => "Gói tập",
                            "LopHoc" => "Lớp học",
                            _ => item.LoaiDichVu
                        };
                    }
                    <div class="flex justify-between items-center mb-3">
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-medium @serviceTypeClass">
                            @serviceTypeText
                        </span>
                        <span class="text-xl font-bold text-blue-600">@string.Format("{0:N0} VNĐ", item.GiaBatDau)</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">@item.TenDichVu</h3>
                    <p class="text-gray-600 mb-4 line-clamp-2">@(item.MoTa != null ? item.MoTa : "Không có mô tả")</p>
                    <div class="flex justify-between items-center">
                        @if (item.LoaiDichVu == "GoiTap" && item.GoiTap != null)
                        {
                            <span class="text-sm text-gray-600"><i class="bi bi-calendar-week mr-1"></i> @item.GoiTap.TenGoi</span>
                        }
                        else if (item.LoaiDichVu == "LopHoc" && item.LopHoc != null)
                        {
                            <span class="text-sm text-gray-600"><i class="bi bi-clock mr-1"></i> @item.LopHoc.NgayTrongTuan</span>
                        }
                        else
                        {
                            <span></span>
                        }
                        <a href="@Url.Action("PublicDetails", new { id = item.MaDichVu })" class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium">
                            Chi tiết <i class="bi bi-arrow-right ml-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
    
    @if (!Model.Any())
    {
        <div class="text-center py-12">
            <div class="text-5xl text-gray-300 mb-4"><i class="bi bi-search"></i></div>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">Không tìm thấy dịch vụ nào</h3>
            <p class="text-gray-500">Vui lòng thử tìm kiếm với từ khóa khác hoặc xóa bộ lọc</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loaiDichVuSelect = document.querySelector('#loaiDichVu');
            loaiDichVuSelect.addEventListener('change', function() {
                this.closest('form').submit();
            });
        });
    </script>
} 