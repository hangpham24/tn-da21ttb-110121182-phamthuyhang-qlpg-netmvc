@model IEnumerable<KLTN.Models.Database.DichVu>

@if (Model != null && Model.Any())
{
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition duration-300 transform hover:-translate-y-1 group">
                <div class="relative h-48 overflow-hidden">
                    @if (!string.IsNullOrEmpty(item.HinhAnhURL))
                    {
                        <img src="@item.HinhAnhURL" alt="@item.TenDichVu" class="w-full h-full object-cover group-hover:scale-105 transition duration-300" 
                             onerror="this.onerror=null; this.src='/img/placeholder.jpg'; this.alt='Hình ảnh không khả dụng';" />
                    }
                    else
                    {
                        <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                            <span class="text-gray-400"><i class="bi bi-image text-4xl"></i></span>
                        </div>
                    }
                    @{
                        var badgeColor = item.LoaiDichVu == "GoiTap" ? "bg-blue-600" : "bg-green-600";
                        var serviceTypeText = item.LoaiDichVu == "GoiTap" ? "Gói tập" : "Lớp học";
                    }
                    <div class="absolute top-0 right-0 m-2">
                        <span class="px-2 py-1 @badgeColor text-white text-xs rounded-full shadow text-center">@serviceTypeText</span>
                    </div>
                </div>
                <div class="p-4">
                    <h3 class="text-lg font-bold text-gray-900 truncate mb-1">@item.TenDichVu</h3>
                    <p class="text-sm text-gray-600 mb-3 line-clamp-2">@(item.MoTa != null ? item.MoTa : "Không có mô tả")</p>
                    <div class="flex justify-between items-center">
                        <span class="text-lg font-bold text-blue-600">@string.Format("{0:N0} VNĐ", item.GiaBatDau)</span>
                        <a href="@Url.Action("PublicDetails", new { id = item.MaDichVu })" class="text-sm text-blue-600 hover:text-blue-800 font-medium">
                            Chi tiết <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-4">
        <p class="text-gray-500">Không có dịch vụ liên quan</p>
    </div>
} 