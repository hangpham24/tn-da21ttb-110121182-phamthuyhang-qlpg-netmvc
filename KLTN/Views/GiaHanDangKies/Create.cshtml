@model KLTN.Models.Database.GiaHanDangKy

@{
    ViewData["Title"] = "Tạo gia hạn đăng ký mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4 bg-white block sm:flex items-center justify-between border-b border-gray-200 lg:mt-1.5 dark:bg-gray-800 dark:border-gray-700">
    <div class="mb-1 w-full">
        <div class="mb-4">
            <h1 class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white">Tạo gia hạn đăng ký mới</h1>
        </div>
    </div>
</div>

<div class="flex flex-col">
    <div class="overflow-x-auto">
        <div class="inline-block min-w-full align-middle">
            <div class="overflow-hidden shadow">
                <form asp-action="Create" class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 sm:p-6 dark:bg-gray-800">
                    <div asp-validation-summary="ModelOnly" class="mb-4 text-sm text-red-600 dark:text-red-500"></div>
                    
                    <div class="grid gap-4 sm:grid-cols-2 sm:gap-6">
                        <div class="sm:col-span-2">
                            <label asp-for="MaDangKy" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <select asp-for="MaDangKy" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" asp-items="ViewBag.MaDangKy">
                                <option value="">-- Chọn đăng ký --</option>
                            </select>
                            <span asp-validation-for="MaDangKy" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>

                        <div class="w-full">
                            <label asp-for="NgayKetThucMoi" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <input asp-for="NgayKetThucMoi" value="@(ViewBag.NgayKetThucCu != null ? ((DateTime)ViewBag.NgayKetThucCu).ToString("yyyy-MM-dd") : "")" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" />
                            <span asp-validation-for="NgayKetThucMoi" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>

                        <div class="w-full">
                            <label asp-for="SoBuoiThem" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <input asp-for="SoBuoiThem" value="@(ViewBag.SoBuoiCu ?? "")" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" />
                            <span asp-validation-for="SoBuoiThem" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>

                        <div class="w-full">
                            <label asp-for="SoTien" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <input asp-for="SoTien" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" />
                            <span asp-validation-for="SoTien" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>

                        <div class="w-full">
                            <label asp-for="NgayGiaHan" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <input asp-for="NgayGiaHan" value="@(ViewBag.NgayDangKyCu != null ? ((DateTime)ViewBag.NgayDangKyCu).ToString("yyyy-MM-dd") : "")" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" />
                            <span asp-validation-for="NgayGiaHan" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>

                        <div class="w-full">
                            <label asp-for="MaTKNguoiThu" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <select asp-for="MaTKNguoiThu" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" asp-items="ViewBag.MaTKNguoiThu">
                                <option value="">-- Chọn người thu --</option>
                            </select>
                            <span asp-validation-for="MaTKNguoiThu" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>

                        <div class="w-full">
                            <label asp-for="TrangThai" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <select asp-for="TrangThai" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500">
                                <option value="DaDong">Đã đóng</option>
                                <option value="ChuaDong">Chưa đóng</option>
                                <option value="DaHuy">Đã hủy</option>
                            </select>
                            <span asp-validation-for="TrangThai" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>

                        <div class="sm:col-span-2">
                            <label asp-for="GhiChu" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"></label>
                            <textarea asp-for="GhiChu" rows="4" class="block p-2.5 w-full text-sm text-gray-900 bg-gray-50 rounded-lg border border-gray-300 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500">@(ViewBag.GhiChuCu ?? "")</textarea>
                            <span asp-validation-for="GhiChu" class="text-sm text-red-600 dark:text-red-500"></span>
                        </div>
                    </div>

                    <div class="flex items-center space-x-4 mt-6">
                        <button type="submit" class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                            Tạo mới
                        </button>
                        <a asp-action="Index" class="text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-700 dark:focus:ring-gray-700">
                            Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
