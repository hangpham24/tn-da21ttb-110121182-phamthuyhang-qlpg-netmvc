@model KLTN.Models.Database.GoiTap

@{
    ViewData["Title"] = "Thêm gói tập";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var goiTap = ViewBag.GoiTap;
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Thêm gói tập mới</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item"><a href="/GoiTaps">Gói tập</a></li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-plus-circle me-1"></i>
            Thông tin gói tập
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="TenGoi" class="control-label"></label>
                            <input asp-for="TenGoi" class="form-control" />
                            <span asp-validation-for="TenGoi" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ThoiHanThang" class="control-label"></label>
                            <input asp-for="ThoiHanThang" class="form-control" />
                            <span asp-validation-for="ThoiHanThang" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="GiaTien" class="control-label"></label>
                            <input asp-for="GiaTien" class="form-control" />
                            <span asp-validation-for="GiaTien" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="SoLanTapToiDa" class="control-label"></label>
                            <input asp-for="SoLanTapToiDa" class="form-control" />
                            <span asp-validation-for="SoLanTapToiDa" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="MaKM" class="control-label"></label>
                            <select asp-for="MaKM" class="form-select" asp-items="ViewBag.MaKM">
                                <option value="">-- Chọn khuyến mãi --</option>
                            </select>
                            <span asp-validation-for="MaKM" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="MoTa" class="control-label"></label>
                    <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="MoTa" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
