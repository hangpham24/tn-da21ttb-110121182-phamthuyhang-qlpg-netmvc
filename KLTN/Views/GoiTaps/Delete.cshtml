@model KLTN.Models.Database.GoiTap

@{
    ViewData["Title"] = "Xóa gói tập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Xóa gói tập</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item"><a href="/GoiTaps">Gói tập</a></li>
        <li class="breadcrumb-item active">Xóa</li>
    </ol>
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-trash me-1"></i>
            Xác nhận xóa
        </div>
        <div class="card-body">
            <div class="alert alert-danger">
                <h4>Bạn có chắc chắn muốn xóa gói tập này?</h4>
                <p>Hành động này không thể hoàn tác.</p>
            </div>
            <dl class="row">
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.TenGoi)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.TenGoi)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.MoTa)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.MoTa)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.ThoiHanThang)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.ThoiHanThang)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.GiaTien)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.GiaTien)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.SoLanTapToiDa)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.SoLanTapToiDa)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.KhuyenMai)
                </dt>
                <dd class="col-sm-10">
                    @(Model.KhuyenMai != null ? Model.KhuyenMai.TenKM : "Không có")
                </dd>
            </dl>
            <form asp-action="Delete">
                <input type="hidden" asp-for="MaGoi" />
                <div class="form-group">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Xác nhận xóa
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
