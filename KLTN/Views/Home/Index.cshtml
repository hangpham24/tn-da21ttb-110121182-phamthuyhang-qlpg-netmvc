<!-- Tính năng nổi bật -->
<section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-3 text-gray-800">Tại sao chọn chúng tôi?</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Chúng tôi cam kết mang đến trải nghiệm tập luyện tốt nhất cho bạn</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition duration-300">
                <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mb-4 mx-auto">
                    <i class="bi bi-gear-wide-connected text-2xl text-blue-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-center text-gray-800">Thiết bị hiện đại</h3>
                <p class="text-gray-600 text-center">Trang bị đầy đủ các thiết bị tập luyện hiện đại, đáp ứng mọi nhu cầu rèn luyện thể chất.</p>
            </div>

            <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition duration-300">
                <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mb-4 mx-auto">
                    <i class="bi bi-person-check text-2xl text-green-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-center text-gray-800">Huấn luyện viên chuyên nghiệp</h3>
                <p class="text-gray-600 text-center">Đội ngũ huấn luyện viên giàu kinh nghiệm, tận tâm hỗ trợ bạn đạt được mục tiêu tập luyện.</p>
            </div>

            <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition duration-300">
                <div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mb-4 mx-auto">
                    <i class="bi bi-calendar-check text-2xl text-purple-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-center text-gray-800">Lịch trình linh hoạt</h3>
                <p class="text-gray-600 text-center">Đa dạng các lớp học và thời gian tập luyện, phù hợp với lịch trình bận rộn của bạn.</p>
            </div>
        </div>
    </div>
</section>

<!-- Tin tức nổi bật -->
<section class="py-16 bg-white">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-3 text-gray-800">Tin tức mới nhất</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Cập nhật những thông tin mới nhất về phòng tập và các hoạt động</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @foreach (var tinTuc in Model.TinTucMoiNhat)
            {
                <div class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition duration-300 transform hover:-translate-y-1 border border-gray-100">
                    <img src="@(string.IsNullOrEmpty(tinTuc.HinhAnhURL) ? "/img/placeholder.jpg" : tinTuc.HinhAnhURL)" 
                         alt="@tinTuc.TieuDe" 
                         class="w-full h-48 object-cover"
                         onerror="this.onerror=null; this.src='/img/placeholder.jpg'; this.alt='Hình ảnh không khả dụng';">
                    <div class="p-6">
                        <div class="flex justify-between items-center mb-2">
                            <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full">
                                @tinTuc.DanhMuc
                            </span>
                            <span class="text-xs text-gray-500">@tinTuc.NgayDang.ToString("dd/MM/yyyy")</span>
                        </div>
                        <h3 class="text-xl font-bold text-gray-800 line-clamp-2">@tinTuc.TieuDe</h3>
                        <p class="text-gray-600 mt-2 mb-4 line-clamp-3">@tinTuc.MoTaNgan</p>
                        <a asp-controller="TinTucs" asp-action="PublicDetails" asp-route-id="@tinTuc.MaTinTuc" class="text-blue-600 hover:text-blue-800 font-medium">
                            Đọc tiếp <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-10">
            <a asp-controller="TinTucs" asp-action="PublicList" class="bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg px-5 py-2.5 transition duration-300">Xem tất cả tin tức</a>
        </div>
    </div>
</section>

<!-- Đăng ký ngay -->
<section class="py-16 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-xl mt-6 mb-6">
    <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Bắt đầu hành trình rèn luyện ngay hôm nay</h2>
        <p class="text-lg text-white mb-8 max-w-2xl mx-auto">Đăng ký thành viên để nhận nhiều ưu đãi đặc biệt và bắt đầu hành trình tập luyện cùng chúng tôi.</p>
        <div class="flex flex-wrap justify-center gap-4">
            <a href="/Identity/Account/Register" class="bg-white text-blue-600 hover:bg-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 text-center transition duration-300 ease-in-out transform hover:-translate-y-1">Đăng ký ngay</a>
            <a href="/LienHe" class="bg-transparent hover:bg-blue-700 border border-white text-white font-medium rounded-lg text-sm px-5 py-2.5 text-center transition duration-300 ease-in-out transform hover:-translate-y-1">Liên hệ tư vấn</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Xử lý fallback cho hình ảnh
        document.addEventListener('DOMContentLoaded', function() {
            const images = document.querySelectorAll('img');
            images.forEach(img => {
                img.addEventListener('error', function() {
                    this.onerror = null;
                    this.src = '/img/placeholder.jpg';
                    this.alt = 'Hình ảnh không khả dụng';
                });
            });
        });
    </script>
}
