@model KLTN.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<section class="bg-gradient-to-r from-blue-600 to-indigo-700 py-16 md:py-24 text-white rounded-xl overflow-hidden">
    <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row items-center">
            <div class="md:w-1/2 mb-8 md:mb-0">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">Chào mừng đến với Gym FitNest</h1>
                <p class="text-lg mb-6">Nơi bạn có thể rèn luyện sức khỏe, cải thiện thể chất và đạt được mục tiêu của mình với sự hỗ trợ từ các huấn luyện viên chuyên nghiệp.</p>
                <div class="flex flex-wrap gap-4">
                    <a href="#dichvu" class="bg-white text-blue-600 hover:bg-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 text-center transition duration-300 ease-in-out transform hover:-translate-y-1">Khám phá dịch vụ</a>
                    <a href="#huanluyenvien" class="bg-transparent hover:bg-blue-700 border border-white text-white font-medium rounded-lg text-sm px-5 py-2.5 text-center transition duration-300 ease-in-out transform hover:-translate-y-1">Huấn luyện viên</a>
                </div>
            </div>
            <div class="md:w-1/2">
                <img src="https://flowbite.s3.amazonaws.com/blocks/marketing-ui/hero/gym-trainer.png" alt="Phòng Gym KLTN" class="rounded-lg shadow-xl hover:shadow-2xl transition duration-300">
            </div>
        </div>
    </div>
</section>

<!-- Thống kê nhanh -->
<section class="py-12 bg-white">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div class="bg-blue-50 p-6 rounded-xl text-center shadow-sm hover:shadow-md transition duration-300">
                <h3 class="text-3xl font-bold text-blue-600 mb-2">@Model.SoLopHoc+</h3>
                <p class="text-gray-700">Lớp học</p>
            </div>
            <div class="bg-green-50 p-6 rounded-xl text-center shadow-sm hover:shadow-md transition duration-300">
                <h3 class="text-3xl font-bold text-green-600 mb-2">@Model.SoGoiTap+</h3>
                <p class="text-gray-700">Gói tập</p>
            </div>
            <div class="bg-purple-50 p-6 rounded-xl text-center shadow-sm hover:shadow-md transition duration-300">
                <h3 class="text-3xl font-bold text-purple-600 mb-2">@Model.SoHuanLuyenVien+</h3>
                <p class="text-gray-700">Huấn luyện viên</p>
            </div>
            <div class="bg-amber-50 p-6 rounded-xl text-center shadow-sm hover:shadow-md transition duration-300">
                <h3 class="text-3xl font-bold text-amber-600 mb-2">@Model.SoThanhVien+</h3>
                <p class="text-gray-700">Thành viên</p>
            </div>
        </div>
    </div>
</section>

<!-- Dịch vụ nổi bật -->
<section id="dichvu" class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-3 text-gray-800">Dịch vụ nổi bật</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Khám phá các dịch vụ đa dạng và các gói tập chất lượng cao của chúng tôi</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @foreach (var dichVu in Model.DichVuNoiBat)
            {
                <div class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition duration-300 transform hover:-translate-y-1">
                    <img src="@(string.IsNullOrEmpty(dichVu.HinhAnhURL) ? "/img/placeholder.jpg" : dichVu.HinhAnhURL)" 
                         alt="@dichVu.TenDichVu" 
                         class="w-full h-56 object-cover"
                         onerror="this.onerror=null; this.src='/img/placeholder.jpg'; this.alt='Hình ảnh không khả dụng';">
                    <div class="p-6">
                        @{ 
                            var typeClass = dichVu.LoaiDichVu == "GoiTap" ? "bg-blue-100 text-blue-800" : "bg-green-100 text-green-800";
                            var typeText = dichVu.LoaiDichVu == "GoiTap" ? "Gói tập" : "Lớp học";
                        }
                        <span class="@typeClass text-xs font-medium px-2.5 py-0.5 rounded-full">
                            @typeText
                        </span>
                        <h3 class="text-xl font-bold text-gray-800 mt-2">@dichVu.TenDichVu</h3>
                        <p class="text-gray-600 mt-2 mb-4 line-clamp-2">@(dichVu.MoTa ?? "Không có mô tả")</p>
                        <div class="flex justify-between items-center">
                            <span class="text-lg font-bold text-blue-600">@string.Format("{0:N0} VNĐ", dichVu.GiaBatDau)</span>
                            @{
                                string detailsUrl = "#";
                                if (dichVu.LoaiDichVu == "GoiTap" && dichVu.MaGoiTap.HasValue)
                                {
                                    detailsUrl = $"/GoiTaps/Details/{dichVu.MaGoiTap}";
                                }
                                else if (dichVu.LoaiDichVu == "LopHoc" && dichVu.MaLopHoc.HasValue)
                                {
                                    detailsUrl = $"/LopHocs/Details/{dichVu.MaLopHoc}";
                                }
                                else
                                {
                                    detailsUrl = $"/DichVus/Details/{dichVu.MaDichVu}";
                                }
                            }
                            <a href="@detailsUrl" 
                               class="text-blue-600 hover:text-blue-800 font-medium">
                                Chi tiết <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-10">
            <a href="/DichVus" class="bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg px-5 py-2.5 transition duration-300">Xem tất cả dịch vụ</a>
        </div>
    </div>
</section>

