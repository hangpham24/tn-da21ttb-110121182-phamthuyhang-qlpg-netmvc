@model IEnumerable<KLTN.Models.Database.HuanLuyenVien>

@{
    ViewData["Title"] = "Quản lý huấn luyện viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Quản lý huấn luyện viên</h1>
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4 gap-2">
        <form method="get" class="flex flex-1 gap-2">
            <input type="text" name="search" value="@(Context.Request.Query["search"])" placeholder="Tìm kiếm theo tên HLV..." class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
                <i class="fas fa-search mr-2"></i>Tìm kiếm
            </button>
            <a href="@Url.Action("Index")" class="px-4 py-2 bg-gray-500 text-white rounded hover:bg-gray-600 flex items-center">
                <i class="fas fa-times mr-2"></i>Xóa bộ lọc
            </a>
        </form>
        <a asp-action="Create" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
            <i class="fas fa-plus mr-2"></i>Tạo huấn luyện viên mới
        </a>
    </div>

    @if (TempData["StatusMessage"] != null)
    {
        <div id="alert-border-3" class="flex items-center p-4 mb-4 text-green-800 border-t-4 border-green-300 bg-green-50" role="alert">
            <i class="fas fa-check-circle flex-shrink-0 w-4 h-4"></i>
            <div class="ml-3 text-sm font-medium">
                @TempData["StatusMessage"]
            </div>
            <button type="button" class="ml-auto -mx-1.5 -my-1.5 bg-green-50 text-green-500 rounded-lg focus:ring-2 focus:ring-green-400 p-1.5 hover:bg-green-200 inline-flex items-center justify-center h-8 w-8" data-dismiss-target="#alert-border-3" aria-label="Close">
                <span class="sr-only">Đóng</span>
                <i class="fas fa-times w-3 h-3"></i>
            </button>
        </div>
    }

    <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Họ tên</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ngày sinh</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Giới tính</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">SĐT</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Chuyên môn</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Trạng thái</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.HoTen</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@(item.NgaySinh.HasValue ? item.NgaySinh.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.GioiTinh</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.SoDienThoai</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.Email</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.ChuyenMon</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                @if (item.TrangThaiHLV == "HoatDong")
                                {
                                    <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Hoạt động</span>
                                }
                                else if (item.TrangThaiHLV == "ChoPheDuyet")
                                {
                                    <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded">Chờ phê duyệt</span>
                                }
                                else if (item.TrangThaiHLV == "Khoa")
                                {
                                    <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded">Khóa</span>
                                }
                                else
                                {
                                    <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded">@item.TrangThaiHLV</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-3">
                                    <a asp-action="Edit" asp-route-id="@item.MaPT" class="text-yellow-500 hover:text-yellow-700 flex items-center">
                                        <i class="bi bi-pencil"></i>Sửa
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaPT" class="text-blue-600 hover:text-blue-900 flex items-center">
                                        <i class="bi bi-eye"></i>Chi tiết
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaPT" class="text-red-600 hover:text-red-900 flex items-center">
                                        <i class="bi bi-trash"></i>Xóa
                                    </a>
                                </div>
                                <div class="flex items-center justify-end space-x-3 mt-2">
                                    @if (item.TrangThaiHLV == "ChoPheDuyet")
                                    {
                                        <form asp-action="UpdateStatus" asp-route-id="@item.MaPT" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="status" value="HoatDong" />
                                            <button type="submit" class="text-green-600 hover:text-green-800 bg-green-100 hover:bg-green-200 px-2 py-1 rounded flex items-center text-xs">
                                                <i class="fas fa-check-circle mr-1"></i>Duyệt
                                            </button>
                                        </form>
                                    }
                                    @if (item.TrangThaiHLV == "Khoa")
                                    {
                                        <form asp-action="UpdateStatus" asp-route-id="@item.MaPT" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="status" value="HoatDong" />
                                            <button type="submit" class="text-green-600 hover:text-green-800 bg-green-100 hover:bg-green-200 px-2 py-1 rounded flex items-center text-xs">
                                                <i class="fas fa-unlock mr-1"></i>Mở khóa
                                            </button>
                                        </form>
                                    }
                                    @if (item.TrangThaiHLV == "HoatDong")
                                    {
                                        <form asp-action="UpdateStatus" asp-route-id="@item.MaPT" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="status" value="Khoa" />
                                            <button type="submit" class="text-red-600 hover:text-red-800 bg-red-100 hover:bg-red-200 px-2 py-1 rounded flex items-center text-xs">
                                                <i class="fas fa-lock mr-1"></i>Khóa
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <div class="mt-4 flex justify-between items-center">
        <div class="text-sm text-gray-700">
            Hiển thị <span class="font-medium">@(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1)</span> đến <span class="font-medium">@(Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems))</span> trong <span class="font-medium">@ViewBag.TotalItems</span> kết quả
        </div>
        <div class="flex items-center space-x-2">
            @if (ViewBag.CurrentPage > 1)
            {
                <a href="@Url.Action("Index", new { page = 1, search = ViewBag.Search })" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                    <i class="bi bi-chevron-double-left"></i>
                </a>
                <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, search = ViewBag.Search })" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                    <i class="bi bi-chevron-left"></i>
                </a>
            }
            @for (var i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="@Url.Action("Index", new { page = i, search = ViewBag.Search })" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium @(i == ViewBag.CurrentPage ? "bg-blue-600 text-white" : "text-gray-700 bg-white hover:bg-gray-50")">
                    @i
                </a>
            }
            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, search = ViewBag.Search })" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                    <i class="bi bi-chevron-right"></i>
                </a>
                <a href="@Url.Action("Index", new { page = ViewBag.TotalPages, search = ViewBag.Search })" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                    <i class="bi bi-chevron-double-right"></i>
                </a>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        setTimeout(function () {
            var alert = document.getElementById('alert-border-3');
            if (alert) {
                alert.remove();
            }
        }, 5000);
    </script>
}
