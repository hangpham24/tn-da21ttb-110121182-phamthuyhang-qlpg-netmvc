@model KLTN.Models.Database.LopHoc

@{
    ViewData["Title"] = "Chi tiết lớp học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Chi tiết lớp học</h1>
        <p class="text-gray-600">Thông tin chi tiết về lớp học</p>
    </div>

    <div class="bg-white shadow-md rounded-lg p-6 max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.TenLop)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @Html.DisplayFor(model => model.TenLop)
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.HuanLuyenVien)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @Html.DisplayFor(model => model.HuanLuyenVien.HoTen)
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.ThoiGianBatDau)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @Html.DisplayFor(model => model.ThoiGianBatDau)
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.ThoiGianKetThuc)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @Html.DisplayFor(model => model.ThoiGianKetThuc)
                    </p>
                </div>
            </div>

            <div class="space-y-4">
                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.NgayTrongTuan)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @Html.DisplayFor(model => model.NgayTrongTuan)
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.SoLuongToiDa)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @Html.DisplayFor(model => model.SoLuongToiDa)
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.SoLuongHienTai)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @Html.DisplayFor(model => model.SoLuongHienTai)
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.TrangThai)
                    </h3>
                    <p class="mt-1">
                        @{
                            var statusClass = "";
                            var statusText = "";
                            
                            if (Model.TrangThai == "DangMo")
                            {
                                statusClass = "bg-green-100 text-green-800";
                                statusText = "Đang mở";
                            }
                            else if (Model.TrangThai == "DaDay")
                            {
                                statusClass = "bg-yellow-100 text-yellow-800";
                                statusText = "Đã đầy";
                            }
                            else
                            {
                                statusClass = "bg-red-100 text-red-800";
                                statusText = "Đã khóa";
                            }
                        }
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full @statusClass">
                            @statusText
                        </span>
                    </p>
                </div>

                <div>
                    <h3 class="text-sm font-medium text-gray-500">
                        @Html.DisplayNameFor(model => model.GhiChu)
                    </h3>
                    <p class="mt-1 text-base text-gray-900">
                        @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có ghi chú" : Model.GhiChu)
                    </p>
                </div>
            </div>
        </div>

        <div class="mt-6 flex items-center justify-end space-x-4">
            <a asp-action="Edit" asp-route-id="@Model?.MaLop" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition flex items-center">
                <i class="fas fa-edit mr-2"></i>Chỉnh sửa
            </a>
            <a asp-action="Index" class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700 transition flex items-center">
                <i class="fas fa-arrow-left mr-2"></i>Quay lại
            </a>
        </div>
    </div>
</div>
