@model KLTN.Models.ViewModels.LopHocViewModel

@{
    ViewData["Title"] = "Chỉnh sửa lớp học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Chỉnh sửa lớp học</h1>
        <p class="text-gray-600">Cập nhật thông tin lớp học</p>
    </div>

    <div class="bg-white shadow-md rounded-lg p-6 max-w-4xl">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
            <input type="hidden" asp-for="MaLop" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-4">
                    <div>
                        <label asp-for="TenLop" class="block text-sm font-medium text-gray-700">Tên lớp</label>
                        <input asp-for="TenLop" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" />
                        <span asp-validation-for="TenLop" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="MaPT" class="block text-sm font-medium text-gray-700">Huấn luyện viên</label>
                        <select asp-for="MaPT" asp-items="ViewBag.MaPT" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500">
                            <option value="">-- Chọn huấn luyện viên --</option>
                        </select>
                        <span asp-validation-for="MaPT" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="ThoiGianBatDau" class="block text-sm font-medium text-gray-700">Thời gian bắt đầu</label>
                        <input asp-for="ThoiGianBatDau" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" />
                        <span asp-validation-for="ThoiGianBatDau" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="ThoiGianKetThuc" class="block text-sm font-medium text-gray-700">Thời gian kết thúc</label>
                        <input asp-for="ThoiGianKetThuc" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" />
                        <span asp-validation-for="ThoiGianKetThuc" class="text-red-500 text-sm"></span>
                    </div>
                </div>

                <div class="space-y-4">
                    <div>
                        <label asp-for="SelectedDays" class="block text-sm font-medium text-gray-700">Chọn ngày trong tuần</label>
                        <div class="mt-2 space-y-2">
                            @foreach (var day in LopHocViewModel.DaysOfWeek)
                            {
                                <div class="flex items-center">
                                    <input type="checkbox" id="day_@day.Replace(" ", "_")" name="SelectedDays" value="@day" 
                                           class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
                                           @(Model.SelectedDays.Contains(day) ? "checked" : "") />
                                    <label for="day_@day.Replace(" ", "_")" class="ml-2 block text-sm text-gray-700">@day</label>
                                </div>
                            }
                        </div>
                        <span asp-validation-for="SelectedDays" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="SoLuongToiDa" class="block text-sm font-medium text-gray-700">Số lượng tối đa</label>
                        <input asp-for="SoLuongToiDa" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" />
                        <span asp-validation-for="SoLuongToiDa" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="SoLuongHienTai" class="block text-sm font-medium text-gray-700">Số lượng hiện tại</label>
                        <input asp-for="SoLuongHienTai" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" />
                        <span asp-validation-for="SoLuongHienTai" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="TrangThai" class="block text-sm font-medium text-gray-700">Trạng thái</label>
                        <select asp-for="TrangThai" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500">
                            <option value="DangMo">Đang mở</option>
                            <option value="DaDay">Đã đầy</option>
                            <option value="DaKhoa">Đã khóa</option>
                        </select>
                        <span asp-validation-for="TrangThai" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="GhiChu" class="block text-sm font-medium text-gray-700">Ghi chú</label>
                        <textarea asp-for="GhiChu" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"></textarea>
                        <span asp-validation-for="GhiChu" class="text-red-500 text-sm"></span>
                    </div>
                </div>
            </div>

            <div class="mt-6 flex items-center justify-end space-x-4">
                <a asp-action="Index" class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700 transition flex items-center">
                    <i class="fas fa-arrow-left mr-2"></i>Quay lại
                </a>
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition flex items-center">
                    <i class="fas fa-save mr-2"></i>Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
