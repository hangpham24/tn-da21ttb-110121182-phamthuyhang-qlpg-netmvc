@model IEnumerable<KLTN.Models.Database.LopHoc>

@{
    ViewData["Title"] = "Quản lý lớp học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    
    var sortOrder = ViewData["CurrentSort"] as string;
    var nameSortParm = ViewData["NameSortParm"] as string;
    var ptSortParm = ViewData["PtSortParm"] as string;
    var statusSortParm = ViewData["StatusSortParm"] as string;
    var currentFilter = ViewData["CurrentFilter"] as string;
    
    var totalItems = ViewBag.TotalItems;
    var totalPages = ViewBag.TotalPages;
    var currentPage = ViewBag.CurrentPage;
    var pageSize = ViewBag.PageSize;
}

<div class="p-4">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Quản lý lớp học</h1>
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4 gap-2">
        <form asp-action="Index" method="get" class="flex flex-1 gap-2">
            <input type="hidden" name="sortOrder" value="@sortOrder" />
            <input type="text" name="search" value="@currentFilter" placeholder="Tìm kiếm theo tên lớp..." class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
                <i class="fas fa-search mr-2"></i>Tìm kiếm
            </button>
            <a asp-action="Index" class="px-4 py-2 bg-gray-500 text-white rounded hover:bg-gray-600 flex items-center">
                <i class="fas fa-times mr-2"></i>Xóa bộ lọc
            </a>
        </form>
        <a asp-action="Create" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
            <i class="fas fa-plus mr-2"></i>Tạo lớp học mới
        </a>
    </div>

    <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@nameSortParm" asp-route-currentFilter="@currentFilter" class="text-gray-500 hover:text-gray-700">
                                Tên lớp
                                @if (sortOrder == "name_desc") {
                                    <i class="bi bi-arrow-down"></i>
                                } else if (string.IsNullOrEmpty(sortOrder)) {
                                    <i class="bi bi-arrow-up"></i>
                                }
                            </a>
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ptSortParm" asp-route-currentFilter="@currentFilter" class="text-gray-500 hover:text-gray-700">
                                Huấn luyện viên
                                @if (sortOrder == "pt_desc") {
                                    <i class="bi bi-arrow-down"></i>
                                } else if (sortOrder == "pt") {
                                    <i class="bi bi-arrow-up"></i>
                                }
                            </a>
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Thời gian bắt đầu</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Thời gian kết thúc</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ngày trong tuần</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Số lượng tối đa</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Số lượng hiện tại</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@statusSortParm" asp-route-currentFilter="@currentFilter" class="text-gray-500 hover:text-gray-700">
                                Trạng thái
                                @if (sortOrder == "status_desc") {
                                    <i class="bi bi-arrow-down"></i>
                                } else if (sortOrder == "status") {
                                    <i class="bi bi-arrow-up"></i>
                                }
                            </a>
                        </th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.TenLop</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.HuanLuyenVien?.HoTen</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.ThoiGianBatDau.ToString(@"hh\:mm")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.ThoiGianKetThuc.ToString(@"hh\:mm")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var day in (item.NgayTrongTuan ?? "").Split(", "))
                                    {
                                        if (!string.IsNullOrWhiteSpace(day))
                                        {
                                            <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2 py-0.5 rounded-full">@day</span>
                                        }
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.SoLuongToiDa</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.SoLuongHienTai</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                @{
                                    var statusClass = "";
                                    var statusText = "";
                                    if (item.TrangThai == "DangMo") { statusClass = "bg-green-100 text-green-800"; statusText = "Đang mở"; }
                                    else if (item.TrangThai == "DaDay") { statusClass = "bg-yellow-100 text-yellow-800"; statusText = "Đã đầy"; }
                                    else { statusClass = "bg-red-100 text-red-800"; statusText = "Đã khóa"; }
                                }
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full @statusClass">@statusText</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-3">
                                    <a asp-action="Edit" asp-route-id="@item.MaLop" class="text-yellow-500 hover:text-yellow-700 flex items-center">
                                        <i class="bi bi-pencil"></i>Sửa
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaLop" class="text-blue-600 hover:text-blue-900 flex items-center">
                                        <i class="bi bi-eye"></i>Chi tiết
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaLop" class="text-red-600 hover:text-red-900 flex items-center">
                                        <i class="bi bi-trash"></i>Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination - Cập nhật theo GoiTaps -->
        @if (totalPages > 1)
        {
            <div class="px-6 py-4 border-t">
                <div class="flex justify-between items-center">
                    <div class="text-sm text-gray-700">
                        Hiển thị @pageSize mục trên tổng số @totalItems mục
                    </div>
                    <div class="flex space-x-2">
                        @if (currentPage > 1)
                        {
                            <a asp-action="Index" asp-route-pageNumber="@(currentPage - 1)" asp-route-sortOrder="@sortOrder" asp-route-currentFilter="@currentFilter"
                               class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        }

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a asp-action="Index" asp-route-pageNumber="@i" asp-route-sortOrder="@sortOrder" asp-route-currentFilter="@currentFilter"
                               class="px-3 py-1 border border-gray-300 rounded @(i == currentPage ? "bg-blue-600 text-white" : "hover:bg-gray-50")">
                                @i
                            </a>
                        }

                        @if (currentPage < totalPages)
                        {
                            <a asp-action="Index" asp-route-pageNumber="@(currentPage + 1)" asp-route-sortOrder="@sortOrder" asp-route-currentFilter="@currentFilter"
                               class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
