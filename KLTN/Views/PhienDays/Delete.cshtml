@model KLTN.Models.Database.PhienDay

@{
    ViewData["Title"] = "Xóa phiên dạy";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 mb-6">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Xóa phiên dạy</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Bạn có chắc chắn muốn xóa phiên dạy này?</p>
    </div>

    <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg mb-6">
        <div class="grid md:grid-cols-2 gap-4">
            <div>
                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.NgayDay)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @(Model.NgayDay != DateTime.MinValue ? Model.NgayDay.ToString("dd/MM/yyyy HH:mm") : "Chưa cập nhật")
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.GiaTriBuoiDay)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @string.Format("{0:N0} VNĐ", Model.GiaTriBuoiDay)
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.LoaiPhienDay)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.LoaiPhienDay)
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.LoaiDichVu)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.LoaiDichVu)
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.TrangThai)
                    </h3>
                    <p class="mt-1">
                        @{
                            var statusClass = Model.TrangThai switch {
                                "DaHoanThanh" => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300",
                                "ChuaHoanThanh" => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300",
                                "DaHuy" => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300",
                                _ => "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300"
                            };

                            var statusText = Model.TrangThai switch {
                                "DaHoanThanh" => "Đã hoàn thành",
                                "ChuaHoanThanh" => "Chưa hoàn thành",
                                "DaHuy" => "Đã hủy",
                                _ => Model.TrangThai
                            };
                        }
                        <span class="px-2.5 py-1 rounded-full text-sm font-medium @statusClass">
                            @statusText
                        </span>
                    </p>
                </div>
            </div>

            <div>
                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.HuanLuyenVien)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.HuanLuyenVien.MaPT)
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.LopHoc)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.LopHoc.NgayTrongTuan)
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.GoiTap)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.GoiTap.TenGoi)
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.BangLuongPT)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.BangLuongPT.MaLuong)
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        @Html.DisplayNameFor(model => model.GhiChu)
                    </h3>
                    <p class="mt-1 text-base font-medium text-gray-900 dark:text-white">
                        @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có ghi chú" : Model.GhiChu)
                    </p>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="MaPhienDay" />
        <div class="flex space-x-3">
            <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                <i class="bi bi-trash me-1"></i> Xóa
            </button>
            <a asp-action="Index" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </form>
</div>
