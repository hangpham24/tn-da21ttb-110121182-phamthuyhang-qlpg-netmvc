@model KLTN.Models.Database.PhienTap

@{
    ViewData["Title"] = "Xóa phiên tập";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 mb-6">
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Xóa phiên tập</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Xác nhận xóa phiên tập khỏi hệ thống</p>
    </div>

    <div class="p-4 mb-6 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-800/20 dark:text-red-400" role="alert">
        <div class="flex items-center">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mr-2 text-lg"></i>
            <span class="font-medium">Cảnh báo!</span>
        </div>
        <div class="mt-2 ml-6">
            Bạn có chắc chắn muốn xóa phiên tập này? Thao tác này không thể hoàn tác và sẽ xóa hoàn toàn dữ liệu này khỏi hệ thống.
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-5">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Thông tin phiên tập</h3>
            
            <div class="space-y-3">
                <div>
                    <p class="text-sm text-gray-500 dark:text-gray-400">@Html.DisplayNameFor(model => model.NgayTap)</p>
                    <p class="text-base font-medium text-gray-900 dark:text-white">@Html.DisplayFor(model => model.NgayTap)</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500 dark:text-gray-400">@Html.DisplayNameFor(model => model.TinhTrang)</p>
                    @if (Model.TinhTrang == "DaHoanThanh")
                    {
                        <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300">
                            Đã hoàn thành
                        </span>
                    }
                    else if (Model.TinhTrang == "DangThucHien")
                    {
                        <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-yellow-900 dark:text-yellow-300">
                            Đang thực hiện
                        </span>
                    }
                    else if (Model.TinhTrang == "DaHuy")
                    {
                        <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-red-900 dark:text-red-300">
                            Đã huỷ
                        </span>
                    }
                    else
                    {
                        <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-gray-700 dark:text-gray-300">
                            @Html.DisplayFor(model => model.TinhTrang)
                        </span>
                    }
                </div>
                
                @if (!string.IsNullOrEmpty(Model.GhiChu))
                {
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">@Html.DisplayNameFor(model => model.GhiChu)</p>
                        <p class="text-base text-gray-900 dark:text-white p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg mt-1">
                            @Html.DisplayFor(model => model.GhiChu)
                        </p>
                    </div>
                }
            </div>
        </div>
        
        <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-5">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Người tham gia</h3>
            
            <div class="space-y-3">
                @if (Model.ThanhVien != null)
                {
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">@Html.DisplayNameFor(model => model.ThanhVien)</p>
                        <p class="text-base font-medium text-gray-900 dark:text-white">
                            @(Model.ThanhVien.HoTen ?? "N/A") <span class="text-xs text-gray-500">(Mã TV: @Model.ThanhVien.MaTV)</span>
                        </p>
                    </div>
                }
                
                @if (Model.KhachVangLai != null)
                {
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">@Html.DisplayNameFor(model => model.KhachVangLai)</p>
                        <p class="text-base font-medium text-gray-900 dark:text-white">
                            @(Model.KhachVangLai.HoTen ?? "N/A") <span class="text-xs text-gray-500">(Mã KVL: @Model.KhachVangLai.MaKVL)</span>
                        </p>
                    </div>
                }
                
                @if (Model.HuanLuyenVien != null)
                {
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">@Html.DisplayNameFor(model => model.HuanLuyenVien)</p>
                        <p class="text-base font-medium text-gray-900 dark:text-white">
                            @(Model.HuanLuyenVien.HoTen ?? "N/A") <span class="text-xs text-gray-500">(Mã PT: @Model.HuanLuyenVien.MaPT)</span>
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <form asp-action="Delete" class="flex items-center space-x-4">
        <input type="hidden" asp-for="MaPhien" />
        <button type="submit" class="inline-flex items-center px-4 py-2 text-sm font-medium text-center text-white bg-red-700 rounded-lg hover:bg-red-800 focus:ring-4 focus:ring-red-300 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-800">
            <i class="bi bi-trash3-fill mr-2"></i>
            Xác nhận xóa
        </button>
        <a asp-action="Index" class="inline-flex items-center px-4 py-2 text-sm font-medium text-center text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 focus:ring-4 focus:ring-gray-200 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-700 dark:focus:ring-gray-700">
            <i class="bi bi-arrow-left mr-2"></i>
            Quay lại
        </a>
    </form>
</div>
