@model IEnumerable<KLTN.Models.Database.PhienTap>

@{
    ViewData["Title"] = "Quản lý phiên tập";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 mb-6">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Danh sách phiên tập</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Quản lý lịch sử tập luyện của thành viên và khách vãng lai</p>
        </div>
        <a asp-action="Create" class="mt-4 md:mt-0 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800">
            <i class="bi bi-plus-circle mr-2"></i>
            Thêm phiên tập mới
        </a>
    </div>

    <div class="relative overflow-x-auto shadow-md sm:rounded-lg">
        <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
            <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                <tr>
                    <th scope="col" class="px-6 py-3">
                        @Html.DisplayNameFor(model => model.NgayTap)
                    </th>
                    <th scope="col" class="px-6 py-3 hidden md:table-cell">
                        @Html.DisplayNameFor(model => model.GhiChu)
                    </th>
                    <th scope="col" class="px-6 py-3">
                        @Html.DisplayNameFor(model => model.TinhTrang)
                    </th>
                    <th scope="col" class="px-6 py-3">
                        @Html.DisplayNameFor(model => model.ThanhVien)
                    </th>
                    <th scope="col" class="px-6 py-3 hidden lg:table-cell">
                        @Html.DisplayNameFor(model => model.KhachVangLai)
                    </th>
                    <th scope="col" class="px-6 py-3 hidden lg:table-cell">
                        @Html.DisplayNameFor(model => model.HuanLuyenVien)
                    </th>
                    <th scope="col" class="px-6 py-3 text-center">
                        <span class="sr-only">Thao tác</span>
                    </th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model) {
                <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                    <td class="px-6 py-4">
                        @Html.DisplayFor(modelItem => item.NgayTap)
                    </td>
                    <td class="px-6 py-4 hidden md:table-cell max-w-xs truncate">
                        @Html.DisplayFor(modelItem => item.GhiChu)
                    </td>
                    <td class="px-6 py-4">
                        @if (item.TinhTrang == "DaHoanThanh")
                        {
                            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300">
                                Đã hoàn thành
                            </span>
                        }
                        else if (item.TinhTrang == "DangThucHien")
                        {
                            <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-yellow-900 dark:text-yellow-300">
                                Đang thực hiện
                            </span>
                        }
                        else if (item.TinhTrang == "DaHuy")
                        {
                            <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-red-900 dark:text-red-300">
                                Đã huỷ
                            </span>
                        }
                        else
                        {
                            <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-gray-700 dark:text-gray-300">
                                @Html.DisplayFor(modelItem => item.TinhTrang)
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4">
                        @(item.ThanhVien?.HoTen ?? "N/A")
                    </td>
                    <td class="px-6 py-4 hidden lg:table-cell">
                        @(item.KhachVangLai?.HoTen ?? "N/A")
                    </td>
                    <td class="px-6 py-4 hidden lg:table-cell">
                        @(item.HuanLuyenVien?.HoTen ?? "N/A")
                    </td>
                     <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-3">
                                    <a asp-action="Edit" asp-route-id="@item.MaPhien" class="text-yellow-500 hover:text-yellow-700 flex items-center">
                                        <i class="bi bi-pencil"></i>Sửa
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaPhien" class="text-blue-600 hover:text-blue-900 flex items-center">
                                        <i class="bi bi-eye"></i>Chi tiết
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaPhien" class="text-red-600 hover:text-red-900 flex items-center">
                                        <i class="bi bi-trash"></i>Xóa
                                    </a>
                                </div>
                            </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
