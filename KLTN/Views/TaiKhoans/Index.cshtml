@model IEnumerable<KLTN.Models.Database.TaiKhoan>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Quản lý tài khoản</h1>
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4 gap-2">
        <form method="get" class="flex flex-1 gap-2">
            <input type="text" name="searchString" value="@(Context.Request.Query["searchString"])" placeholder="Tìm kiếm theo tên đăng nhập..." class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
                <i class="fas fa-search mr-2"></i>Tìm kiếm
            </button>
            <a href="@Url.Action("Index")" class="px-4 py-2 bg-gray-500 text-white rounded hover:bg-gray-600 flex items-center">
                <i class="fas fa-times mr-2"></i>Xóa bộ lọc
            </a>
        </form>
        <a asp-action="Create" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
            <i class="fas fa-plus mr-2"></i>Tạo tài khoản mới
        </a>
    </div>

    <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]" class="flex items-center">
                                Tên đăng nhập
                                @if (ViewData["CurrentSort"]?.ToString() == "name_desc")
                                {
                                    <i class="fas fa-sort-down ml-1"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "")
                                {
                                    <i class="fas fa-sort-up ml-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-sort ml-1"></i>
                                }
                            </a>
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["StatusSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]" class="flex items-center">
                                Trạng thái
                                @if (ViewData["CurrentSort"]?.ToString() == "status_desc")
                                {
                                    <i class="fas fa-sort-down ml-1"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "status")
                                {
                                    <i class="fas fa-sort-up ml-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-sort ml-1"></i>
                                }
                            </a>
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]" class="flex items-center">
                                Ngày tạo
                                @if (ViewData["CurrentSort"]?.ToString() == "date_desc")
                                {
                                    <i class="fas fa-sort-down ml-1"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "date")
                                {
                                    <i class="fas fa-sort-up ml-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-sort ml-1"></i>
                                }
                            </a>
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["LastLoginSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]" class="flex items-center">
                                Lần đăng nhập cuối
                                @if (ViewData["CurrentSort"]?.ToString() == "lastlogin_desc")
                                {
                                    <i class="fas fa-sort-down ml-1"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "lastlogin")
                                {
                                    <i class="fas fa-sort-up ml-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-sort ml-1"></i>
                                }
                            </a>
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Quyền</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.TenDangNhap</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                @if (item.TrangThai == "HoatDong")
                                {
                                    <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Hoạt động</span>
                                }
                                else if (item.TrangThai == "Khoa")
                                {
                                    <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded">Khóa</span>
                                }
                                else if (item.TrangThai == "ChuaKichHoat")
                                {
                                    <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded">Chưa kích hoạt</span>
                                }
                                else
                                {
                                    <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded">@item.TrangThai</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@(item.LanDangNhapCuoi.HasValue ? item.LanDangNhapCuoi.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa đăng nhập")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.Quyen?.TenQuyen</td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-3">
                                    <a asp-action="Edit" asp-route-id="@item.MaTK" class="flex items-center text-[#F59E0B] hover:text-orange-700">
                                        <i class="bi bi-pencil"></i>Sửa
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaTK" class="flex items-center text-blue-600 hover:text-blue-800">
                                        <i class="bi bi-eye"></i>Chi tiết
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaTK" class="flex items-center text-red-600 hover:text-red-800">
                                        <i class="bi bi-trash"></i>Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="mt-4 flex justify-center">
            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                @{
                    var prevDisabled = ViewBag.CurrentPage == 1 ? "pointer-events-none opacity-50" : "";
                    var nextDisabled = ViewBag.CurrentPage == ViewBag.TotalPages ? "pointer-events-none opacity-50" : "";
                }
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["CurrentSort"]"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   asp-route-pageNumber="@(ViewBag.CurrentPage - 1)"
                   class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 @prevDisabled">
                    <span class="sr-only">Previous</span>
                    <i class="fas fa-chevron-left"></i>
                </a>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    var activeClass = i == ViewBag.CurrentPage ? "z-10 bg-blue-50 border-blue-500 text-blue-600" : "bg-white border-gray-300 text-gray-500 hover:bg-gray-50";
                    <a asp-action="Index"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-currentFilter="@ViewData["CurrentFilter"]"
                       asp-route-pageNumber="@i"
                       class="relative inline-flex items-center px-4 py-2 border text-sm font-medium @activeClass">
                        @i
                    </a>
                }

                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["CurrentSort"]"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   asp-route-pageNumber="@(ViewBag.CurrentPage + 1)"
                   class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 @nextDisabled">
                    <span class="sr-only">Next</span>
                    <i class="fas fa-chevron-right"></i>
                </a>
            </nav>
        </div>
    }
</div>
