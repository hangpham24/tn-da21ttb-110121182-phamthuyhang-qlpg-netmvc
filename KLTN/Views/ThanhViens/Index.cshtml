@model IEnumerable<KLTN.Models.Database.ThanhVien>

@{
    ViewData["Title"] = "Quản lý thành viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Quản lý thành viên</h1>
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4 gap-2">
        <form method="get" class="flex flex-1 gap-2">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" placeholder="Tìm kiếm theo tên, email, SĐT, địa chỉ..." class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
                <i class="fas fa-search mr-2"></i>Tìm kiếm
            </button>
            <a href="@Url.Action("Index")" class="px-4 py-2 bg-gray-500 text-white rounded hover:bg-gray-600 flex items-center">
                <i class="fas fa-times mr-2"></i>Xóa bộ lọc
            </a>
        </form>
        <a asp-action="Create" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center">
            <i class="fas fa-plus mr-2"></i>Tạo thành viên mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="alert-success" class="flex items-center p-4 mb-4 text-green-800 rounded-lg bg-green-50">
            <i class="fas fa-check-circle mr-2"></i>
            <span class="font-medium">@TempData["SuccessMessage"]</span>
            <button type="button" class="ml-auto -mx-1.5 -my-1.5 bg-green-50 text-green-500 rounded-lg focus:ring-2 focus:ring-green-400 p-1.5 hover:bg-green-200 inline-flex items-center justify-center h-8 w-8" data-dismiss-target="#alert-success" aria-label="Close">
                <span class="sr-only">Đóng</span>
                <i class="fas fa-times w-3 h-3"></i>
            </button>
        </div>
    }

    <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mã TV</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]" class="flex items-center">
                                Họ tên
                                @if (ViewData["CurrentSort"]?.ToString() == "name_desc")
                                {
                                    <i class="fas fa-sort-down ml-1"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "")
                                {
                                    <i class="fas fa-sort-up ml-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-sort ml-1"></i>
                                }
                            </a>
            </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]" class="flex items-center">
                                Ngày sinh
                                @if (ViewData["CurrentSort"]?.ToString() == "date_desc")
                                {
                                    <i class="fas fa-sort-down ml-1"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "date")
                                {
                                    <i class="fas fa-sort-up ml-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-sort ml-1"></i>
                                }
                            </a>
            </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Giới tính</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">SĐT</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["EmailSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]" class="flex items-center">
                                Email
                                @if (ViewData["CurrentSort"]?.ToString() == "email_desc")
                                {
                                    <i class="fas fa-sort-down ml-1"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "email")
                                {
                                    <i class="fas fa-sort-up ml-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-sort ml-1"></i>
                                }
                            </a>
            </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Địa chỉ</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tài khoản</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Thao tác</th>
        </tr>
    </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-center">@item.MaTV</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10 mr-2">
                                        @if (!string.IsNullOrEmpty(item.AnhDaiDien))
                                        {
                                            <img class="h-10 w-10 rounded-full object-cover" src="@item.AnhDaiDien" alt="@item.HoTen">
                                        }
                                        else
                                        {
                                            <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center">
                                                <span class="text-gray-500 text-xs font-bold">@(item.HoTen?.Substring(0, 1).ToUpper() ?? "U")</span>
                                            </div>
                                        }
                                    </div>
                                    <span class="font-medium">@item.HoTen</span>
                                </div>
            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@((item.NgaySinh.HasValue) ? item.NgaySinh.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.GioiTinh</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.SoDienThoai</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.Email</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.DiaChi</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                @if (item.TaiKhoan != null)
                                {
                                    <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">@item.TaiKhoan.TenDangNhap</span>
                                }
                                else
                                {
                                    <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded">Chưa có tài khoản</span>
                                }
            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-3">
                                    <a asp-action="Edit" asp-route-id="@item.MaTV" class="text-yellow-500 hover:text-yellow-700 flex items-center">
                                        <i class="bi bi-pencil"></i>Sửa
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaTV" class="text-blue-600 hover:text-blue-900 flex items-center">
                                        <i class="bi bi-eye"></i>Chi tiết
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaTV" class="text-red-600 hover:text-red-900 flex items-center">
                                        <i class="bi bi-trash"></i>Xóa
                                    </a>
                                </div>
            </td>
        </tr>
}
    </tbody>
</table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="px-6 py-4 border-t">
                <div class="flex justify-between items-center">
                    <div class="text-sm text-gray-700">
                        Hiển thị @ViewBag.PageSize mục trên tổng số @ViewBag.TotalItems mục
                    </div>
                    <div class="flex space-x-2">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a asp-action="Index" 
                               asp-route-pageNumber="@(ViewBag.CurrentPage - 1)" 
                               asp-route-sortOrder="@ViewData["CurrentSort"]" 
                               asp-route-currentFilter="@ViewData["CurrentFilter"]"
                               class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        }

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <a asp-action="Index" 
                               asp-route-pageNumber="@i" 
                               asp-route-sortOrder="@ViewData["CurrentSort"]" 
                               asp-route-currentFilter="@ViewData["CurrentFilter"]"
                               class="px-3 py-1 border border-gray-300 rounded @(i == ViewBag.CurrentPage ? "bg-blue-600 text-white" : "hover:bg-gray-50")">
                                @i
                            </a>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a asp-action="Index" 
                               asp-route-pageNumber="@(ViewBag.CurrentPage + 1)" 
                               asp-route-sortOrder="@ViewData["CurrentSort"]" 
                               asp-route-currentFilter="@ViewData["CurrentFilter"]"
                               class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

