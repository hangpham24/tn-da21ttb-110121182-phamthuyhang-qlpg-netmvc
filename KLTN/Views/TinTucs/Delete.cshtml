@model KLTN.Models.Database.TinTuc

@{
    ViewData["Title"] = "Xóa tin tức";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 mb-6">
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Xóa tin tức</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Xác nhận xóa tin tức khỏi hệ thống</p>
    </div>

    <div class="p-4 mb-6 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-800/20 dark:text-red-400" role="alert">
        <div class="flex items-center">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mr-2 text-lg"></i>
            <span class="font-medium">Cảnh báo!</span>
        </div>
        <div class="mt-2 ml-6">
            Bạn có chắc chắn muốn xóa tin tức này? Thao tác này không thể hoàn tác và sẽ xóa hoàn toàn dữ liệu này khỏi hệ thống.
        </div>
    </div>

    <div class="p-5 bg-gray-50 rounded-lg dark:bg-gray-700 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">@Html.DisplayFor(model => model.TieuDe)</h3>
                
                <div class="space-y-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@Html.DisplayNameFor(model => model.TacGiaDisplay):</label>
                        <div class="text-sm text-gray-900 dark:text-white">@Html.DisplayFor(model => model.TacGiaDisplay)</div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@Html.DisplayNameFor(model => model.NgayDang):</label>
                        <div class="text-sm text-gray-900 dark:text-white">@Html.DisplayFor(model => model.NgayDang)</div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@Html.DisplayNameFor(model => model.TrangThai):</label>
                        @if (Model.TrangThai == "Đã duyệt")
                        {
                            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300">
                                @Html.DisplayFor(model => model.TrangThai)
                            </span>
                        }
                        else if (Model.TrangThai == "Chờ duyệt")
                        {
                            <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-yellow-900 dark:text-yellow-300">
                                @Html.DisplayFor(model => model.TrangThai)
                            </span>
                        }
                        else
                        {
                            <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-red-900 dark:text-red-300">
                                @Html.DisplayFor(model => model.TrangThai)
                            </span>
                        }
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@Html.DisplayNameFor(model => model.TaiKhoan):</label>
                        <div class="text-sm text-gray-900 dark:text-white">@Html.DisplayFor(model => model.TaiKhoan.TenDangNhap)</div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@Html.DisplayNameFor(model => model.DanhMuc):</label>
                        <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-blue-900 dark:text-blue-300">
                            @(Model.DanhMuc == "TinTuc" ? "Tin tức" : 
                              Model.DanhMuc == "SuKien" ? "Sự kiện" : 
                              Model.DanhMuc == "KhuyenMai" ? "Khuyến mãi" : 
                              Model.DanhMuc == "Blog" ? "Blog" : Model.DanhMuc)
                        </span>
                    </div>
                </div>
            </div>
            
            <div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@Html.DisplayNameFor(model => model.MoTaNgan):</label>
                    <div class="text-sm text-gray-900 dark:text-white p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg">
                        @Html.DisplayFor(model => model.MoTaNgan)
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.HinhAnhURL))
                {
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Hình ảnh:</label>
                        <img src="@Model.HinhAnhURL" alt="@Model.TieuDe" class="h-32 w-auto object-cover rounded-lg">
                    </div>
                }
                
                <div class="mt-4 flex space-x-4">
                    <div class="flex items-center">
                        <div class="mr-2 @(Model.HienThi ? "text-blue-600 dark:text-blue-500" : "text-gray-400 dark:text-gray-500")">
                            <i class="bi @(Model.HienThi ? "bi-eye-fill" : "bi-eye-slash")"></i>
                        </div>
                        <span class="text-sm">@(Model.HienThi ? "Hiển thị" : "Ẩn")</span>
                    </div>
                    
                    <div class="flex items-center">
                        <div class="mr-2 @(Model.NoiBat ? "text-yellow-600 dark:text-yellow-500" : "text-gray-400 dark:text-gray-500")">
                            <i class="bi @(Model.NoiBat ? "bi-star-fill" : "bi-star")"></i>
                        </div>
                        <span class="text-sm">@(Model.NoiBat ? "Nổi bật" : "Bình thường")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <form asp-action="Delete" class="flex items-center space-x-4">
        <input type="hidden" asp-for="MaTinTuc" />
        <button type="submit" class="inline-flex items-center px-4 py-2 text-sm font-medium text-center text-white bg-red-700 rounded-lg hover:bg-red-800 focus:ring-4 focus:ring-red-300 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-800">
            <i class="bi bi-trash3-fill mr-2"></i>
            Xác nhận xóa
        </button>
        <a asp-action="Index" class="inline-flex items-center px-4 py-2 text-sm font-medium text-center text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 focus:ring-4 focus:ring-gray-200 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-700 dark:focus:ring-gray-700">
            <i class="bi bi-arrow-left mr-2"></i>
            Quay lại
        </a>
    </form>
</div>
